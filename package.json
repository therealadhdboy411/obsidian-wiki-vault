{
  "name": "obsidian-vault-wiki",
  "version": "1.1.0",
  "description": "AI-powered wiki note generator for Obsidian. Free, open-source, pro-consumer.",
  "main": "main.js",
  "author": "adhdboy411",
  "license": "Apache-2.0",
  "homepage": "https://github.com/adhdboy411/vault-wiki#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/adhdboy411/vault-wiki.git"
  },
  "bugs": {
    "url": "https://github.com/adhdboy411/vault-wiki/issues"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "wiki",
    "ai",
    "llm",
    "knowledge-base",
    "ollama",
    "lmstudio",
    "mistral",
    "openai",
    "anthropic",
    "notes",
    "zettelkasten"
  ],

  "scripts": {
    "build":       "node esbuild.config.mjs",
    "dev":         "node esbuild.config.mjs --watch",
    "build:prod":  "NODE_ENV=production node esbuild.config.mjs",
    "lint":        "eslint src --ext .ts,.js",
    "lint:fix":    "eslint src --ext .ts,.js --fix",
    "type-check":  "tsc --noEmit",
    "test":        "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch":  "node --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "docs":        "typedoc src/main.ts --out docs/api",
    "validate":    "node --check main.js && echo '✅ main.js syntax OK'",
    "prerelease":  "npm run lint && npm run type-check && npm run build:prod && npm run validate",
    "release":     "node scripts/release.mjs",
    "debug:dump":  "node scripts/debug-dump.mjs",
    "debug:settings": "node scripts/debug-settings.mjs",
    "format":      "prettier --write src/**/*.ts"
  },

  "dependencies": {},

  "devDependencies": {
    "@types/node":             "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser":        "^6.0.0",
    "builtin-modules":         "^3.3.0",
    "esbuild":                 "^0.25.0",
    "eslint":                  "^8.0.0",
    "jest":                    "^29.0.0",
    "obsidian":                "latest",
    "prettier":                "^3.0.0",
    "tslib":                   "^2.6.0",
    "typedoc":                 "^0.25.0",
    "typescript":              "^5.3.0"
  },

  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleNameMapper": {
      "^obsidian$": "<rootDir>/src/__mocks__/obsidian.ts"
    },
    "testPathPattern": "src/__tests__",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/__mocks__/**",
      "!src/**/__tests__/**"
    ]
  },

  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  },

  "eslintConfig": {
    "root": true,
    "parser": "@typescript-eslint/parser",
    "plugins": ["@typescript-eslint"],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ],
    "rules": {
      "no-console":              "warn",
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/no-unused-vars":  ["error", { "argsIgnorePattern": "^_" }],
      "prefer-const":            "error",
      "no-var":                  "error"
    },
    "env": {
      "browser": true,
      "es2022":  true
    }
  },

  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=9.0.0"
  }
}
